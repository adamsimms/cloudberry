# Pinchard's Island rig secrets — copy to secrets.env and fill in values.
# secrets.env is gitignored; keep a backup in your password manager.
#
#   cp .env.example secrets.env
#
# On the Pi, either secrets.env in the repo dir or ~/.cloudberry/secrets.env works.
# Optional: export CLOUDBERRY_SECRETS_FILE=/path/to/secrets.env

# --- AWS (S3 upload for pinchards.is gallery) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_DEFAULT_REGION=us-east-1

# --- GoPro HERO4 Wi-Fi ---
GOPRO_WIFI_PASSWORD=
GOPRO_AP_PASSWORD=
GOPRO_MAC_ADDRESS=D4:D9:19:9A:00:5A

# --- Island network (reference; usually in wpa_supplicant on the Pi) ---
GOPRO_WIFI_SSID=shutterisland
HUAWEI_LTE_ADMIN_PASSWORD=
CAMDO_WIFI_PASSWORD=

# --- Remote access (rotate if still in use) ---
DATAPLICITY_INSTALL_TOKEN=

# --- Camera Suite registration (legacy) ---
CAMERASUITE_EMAIL=
CAMERASUITE_SERIAL=

# --- SMTP alerts (optional; see logging.ini) ---
SMTP_HOST=
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
