# Pinchard's Island rig secrets — copy to secrets.env and fill in values.
# secrets.env is gitignored; keep a backup in your password manager.
#
#   cp .env.example secrets.env
#
# On the Pi, either secrets.env in the repo dir or ~/.cloudberry/secrets.env works.
# Optional: export CLOUDBERRY_SECRETS_FILE=/path/to/secrets.env
#
# Island Wi‑Fi and GoPro field notes: docs/field/secrets-reference.md (not loaded by the app).

# --- AWS (S3 upload for pinchards.is gallery) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_DEFAULT_REGION=us-east-1

# --- GoPro HERO4 Wi-Fi ---
GOPRO_WIFI_PASSWORD=
GOPRO_MAC_ADDRESS=AA:BB:CC:DD:EE:FF
